{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!guide|assets|sw\\.js|manifest\\.webmanifest|robots\\.txt|sitemap\\.xml|favicon\\.ico|logo\\.svg|og-image\\.png|pwa-.*|maskable-.*|apple-touch-icon-.*).*)", "destination": "/index.html" }
  ]
}
